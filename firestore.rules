rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ─── Users ──────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Any authenticated user can read profiles (needed for reporter info, community display, etc.)
      allow read: if isAuth();

      // Create your own user document on registration
      allow create: if isOwner(userId);

      // Update your own profile — CANNOT modify admin/moderation/reputation fields
      // This prevents self-promotion to admin or self-boosting of points/trust
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isAdmin', 'role', 'isBanned', 'banReason', 'isSuspended', 'suspendedUntil']);

      // Update reputation/level fields only — allowed from any authenticated user.
      // Required because vote transactions (running under voter's auth) must update
      // the reporter's points and level. TODO: migrate to Cloud Functions for
      // server-side enforcement to fully prevent point manipulation.
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['points', 'level', 'levelTitle', 'isTrusted', 'votes', 'reports']);

      // Admins can fully read/write any user document (moderation, role management, banning)
      allow write: if isAdmin();
    }

    // ─── Incidents ──────────────────────────────────────────────────────────

    match /incidents/{incidentId} {
      allow read: if isAuth();

      // Reporter ID must match the authenticated user
      allow create: if isAuth()
        && request.resource.data.reporterId == request.auth.uid;

      // Reporter or admin can fully update the incident
      allow update: if isAuth()
        && (resource.data.reporterId == request.auth.uid || isAdmin());

      // Any authenticated user can update vote-count and status fields only.
      // Required for client-side vote transactions where the voter is not the reporter.
      // TODO: migrate to Cloud Functions to enforce rate limiting and prevent direct manipulation.
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['upvotes', 'downvotes', 'status', 'statusUpdatedAt', 'statusNote', 'statusHistory']);

      // Only reporter or admin can delete
      allow delete: if isAuth()
        && (resource.data.reporterId == request.auth.uid || isAdmin());
    }

    // ─── Votes ──────────────────────────────────────────────────────────────

    match /votes/{voteId} {
      allow read: if isAuth();

      // Vote ID format is "{incidentId}_{voterId}" — enforce both ownership and ID pattern
      allow create: if isAuth()
        && request.resource.data.voterId == request.auth.uid
        && voteId == request.resource.data.get('incidentId', '') + '_' + request.auth.uid;

      // Only the original voter can change or remove their vote
      allow update, delete: if isAuth()
        && resource.data.voterId == request.auth.uid;
    }

    // ─── Categories ─────────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if isAuth();
      // Only admins can create, modify, or delete categories
      allow write: if isAdmin();
    }

    // ─── Communities ────────────────────────────────────────────────────────

    match /communities/{communityId} {
      allow read: if isAuth();
      allow create: if isAuth();

      // Only the creator or a system admin can change community settings
      allow update: if isAuth()
        && (resource.data.createdBy == request.auth.uid || isAdmin());

      // Only system admins can delete communities
      allow delete: if isAdmin();
    }

    // ─── Community Members (root-level collection) ───────────────────────────

    match /community_members/{memberId} {
      allow read: if isAuth();

      // Users can only create a membership record for themselves
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;

      // Members can update/delete their own membership (leave, update status)
      // Admins can manage all memberships (approve, reject, promote, demote)
      allow update, delete: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ─── Posts ──────────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow read: if isAuth();

      allow create: if isAuth()
        && request.resource.data.authorId == request.auth.uid;

      // Author or admin can edit/delete posts
      allow update, delete: if isAuth()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ─── Comments ───────────────────────────────────────────────────────────

    match /comments/{commentId} {
      allow read: if isAuth();

      allow create: if isAuth()
        && request.resource.data.authorId == request.auth.uid;

      // Author or admin can edit/delete comments
      allow update, delete: if isAuth()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ─── Flags ──────────────────────────────────────────────────────────────

    match /flags/{flagId} {
      // Only admins can view and manage flags
      allow read, update, delete: if isAdmin();

      // Any authenticated user can submit a flag/report
      allow create: if isAuth();
    }
  }
}
