rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ─── Users ──────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Any authenticated user can read profiles (needed for reporter info, community display, etc.)
      allow read: if isAuth();

      // Create your own user document on registration
      allow create: if isOwner(userId);

      // Update your own profile — CANNOT modify admin/moderation/reputation fields
      // This prevents self-promotion to admin or self-boosting of points/trust
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isAdmin', 'role', 'isBanned', 'banReason', 'isSuspended', 'suspendedUntil']);

      // Update reputation/level fields only — allowed from any authenticated user.
      // Required because vote transactions (running under voter's auth) must update
      // the reporter's points and level. TODO: migrate to Cloud Functions for
      // server-side enforcement to fully prevent point manipulation.
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['points', 'level', 'levelTitle', 'isTrusted', 'votes', 'reports']);

      // Admins can fully read/write any user document (moderation, role management, banning)
      allow write: if isAdmin();
    }

    // ─── Incidents ──────────────────────────────────────────────────────────

    match /incidents/{incidentId} {
      allow read: if isAuth();

      // Reporter ID must match the authenticated user
      allow create: if isAuth()
        && request.resource.data.reporterId == request.auth.uid;

      // Reporter or admin can fully update the incident
      allow update: if isAuth()
        && (resource.data.reporterId == request.auth.uid || isAdmin());

      // Any authenticated user can update vote-count and status fields only.
      // Required for client-side vote transactions where the voter is not the reporter.
      // TODO: migrate to Cloud Functions to enforce rate limiting and prevent direct manipulation.
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['upvotes', 'downvotes', 'status', 'statusUpdatedAt', 'statusNote', 'statusHistory']);

      // Only reporter or admin can delete
      allow delete: if isAuth()
        && (resource.data.reporterId == request.auth.uid || isAdmin());
    }

    // ─── Votes ──────────────────────────────────────────────────────────────

    match /votes/{voteId} {
      allow read: if isAuth();

      // Vote ID format is "{targetId}_{voterId}" — enforce both ownership and ID pattern.
      // Falls back to legacy 'incidentId' field for backward compatibility with existing vote docs.
      allow create: if isAuth()
        && request.resource.data.voterId == request.auth.uid
        && voteId == request.resource.data.get('targetId', request.resource.data.get('incidentId', '')) + '_' + request.auth.uid;

      // Only the original voter can change or remove their vote
      allow update, delete: if isAuth()
        && resource.data.voterId == request.auth.uid;
    }

    // ─── Categories ─────────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if isAuth();
      // Only admins can create, modify, or delete categories
      allow write: if isAdmin();
    }

    // ─── Communities ────────────────────────────────────────────────────────

    match /communities/{communityId} {
      allow read: if isAuth();
      allow create: if isAuth();

      // Community creator or system admin can update community settings.
      // NOTE: field is 'creatorId' (was incorrectly 'createdBy' — caused creator updates to fail).
      allow update: if isAuth()
        && (resource.data.creatorId == request.auth.uid || isAdmin());

      // Any authenticated user can update memberCount only.
      // Required for join/leave operations where the requester is not the creator.
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberCount']);

      // Community creator or system admin can delete.
      allow delete: if isAuth()
        && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    // ─── Community Members (root-level collection) ───────────────────────────
    // Role hierarchy: owner > headModerator > moderator > member
    // Roles stored as string names (e.g. "owner", "headModerator", "moderator", "member").
    // Staff roles (owner/headModerator/moderator) grant access to management actions.

    match /community_members/{memberId} {
      allow read: if isAuth();

      // Users can only create a membership record for themselves.
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;

      // Members can update or delete their own membership (e.g. leave community).
      allow update, delete: if isAuth()
        && resource.data.userId == request.auth.uid;

      // Staff actions: approve/reject requests, promote/demote members, transfer ownership.
      // Membership IDs are auto-generated so staff role cannot be verified here —
      // app layer enforces role-based permission checks before calling Firestore.
      // TODO: migrate to Cloud Functions for server-side enforcement in production.
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'approvedAt', 'approvedBy', 'role']);

      // Remove member: app layer enforces community staff role and prevents owner removal.
      // TODO: migrate to Cloud Functions for server-side enforcement in production.
      allow delete: if isAuth();
    }

    // ─── Posts ──────────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow read: if isAuth();

      allow create: if isAuth()
        && request.resource.data.authorId == request.auth.uid;

      // Author or admin can edit/delete posts
      allow update, delete: if isAuth()
        && (resource.data.authorId == request.auth.uid || isAdmin());

      // Any authenticated user can update vote-count fields only.
      // Required for client-side post vote transactions where the voter is not the author.
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['upvotes', 'downvotes']);
    }

    // ─── Comments ───────────────────────────────────────────────────────────

    match /comments/{commentId} {
      allow read: if isAuth();

      allow create: if isAuth()
        && request.resource.data.authorId == request.auth.uid;

      // Author or admin can edit/delete comments
      allow update, delete: if isAuth()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ─── Flags ──────────────────────────────────────────────────────────────

    match /flags/{flagId} {
      // Only admins can view and manage flags
      allow read, update, delete: if isAdmin();

      // Any authenticated user can submit a flag/report
      allow create: if isAuth();
    }

    // ─── Admin Audit Log ────────────────────────────────────────────────────

    match /admin_audit_log/{entryId} {
      // Only admins can read the audit log
      allow read: if isAdmin();

      // Any authenticated user can write — entries are created by admin actions
      // running under the admin's own auth token. isAdmin() check is enforced
      // at the app layer before any audit write is triggered.
      allow create: if isAuth();

      // Audit entries are immutable — no updates or deletes allowed.
      allow update, delete: if false;
    }
  }
}
